{
  "name": "cloak",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:root": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "db:push": "turbo db:push --filter=@cloak/api",
    "db:generate": "turbo db:generate --filter=@cloak/api",
    "db:migrate": "turbo db:migrate --filter=@cloak/api"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.8"
    }
  }
}
