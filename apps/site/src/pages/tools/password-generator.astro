---
import Base from '../../layouts/Base.astro';

const title = 'Free Password Generator + Strength Meter — Cryptographically Secure';
const description =
  'Generate strong passwords in your browser using cryptographic randomness. Real-time entropy + crack-time estimates. No server, no logs, no signup. Free.';

const faqs = [
  {
    question: 'Is this password generator really secure?',
    answer:
      "Yes. The generator uses crypto.getRandomValues() — your browser's cryptographically secure random source, the same primitive used by TLS and password managers. Passwords are generated entirely in your browser. They never leave your machine. There is no network request when you click Generate.",
  },
  {
    question: 'How is password strength calculated?',
    answer:
      "The strength meter estimates entropy in bits using the Shannon formula: log2(charset_size) × length. The crack-time estimate uses Hashcat's published rate for bcrypt (10,000 hashes/sec on a single GPU) and assumes the attacker has stolen the hash. Higher numbers = exponentially harder to crack.",
  },
  {
    question: 'What length should I use?',
    answer:
      'For accounts that matter (banking, work email, password manager master password): 20+ characters with mixed case, numbers, and symbols (≥130 bits of entropy). For throwaway accounts: 16 characters is plenty. Length matters far more than complexity rules — a 24-character lowercase-only password is much stronger than an 8-character password with all character classes.',
  },
  {
    question: 'Why do you exclude similar-looking characters?',
    answer:
      "Optionally excluding 0/O/o, 1/l/I makes passwords easier to read aloud or transcribe from paper without losing meaningful entropy. The strength meter accounts for the reduced charset.",
  },
  {
    question: 'How do I share this password securely?',
    answer:
      "Don't email or message it. Use CloakShare's secure-link feature: generate a one-time tracked link, set an expiry, and send the link instead. The recipient opens it once and the secret is gone. Built specifically for this use case.",
  },
];

const breadcrumbItems = [
  { name: 'Home', url: 'https://cloakshare.dev/' },
  { name: 'Tools', url: 'https://cloakshare.dev/tools' },
  { name: 'Password Generator', url: 'https://cloakshare.dev/tools/password-generator' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: b.url,
      })),
    },
    {
      '@type': 'WebApplication',
      name: 'Free Password Generator',
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'Web Browser',
      description,
      url: 'https://cloakshare.dev/tools/password-generator',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
  ],
};
---

<Base title={title} description={description} canonical="/tools/password-generator">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    is:inline
  />

  <main class="pt-32 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Hero -->
      <section class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent/30 bg-accent-muted text-xs text-accent font-mono mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          Free · No signup · Runs in your browser
        </div>
        <h1 class="text-4xl md:text-5xl font-mono font-bold text-foreground tracking-tight mb-4">
          Free Password Generator
        </h1>
        <p class="text-lg text-text-secondary font-sans max-w-2xl mx-auto">
          Cryptographically secure passwords. Real-time strength meter. No network requests, no logs, no signup. Your password never leaves your browser.
        </p>
      </section>

      <!-- Generator -->
      <section class="rounded-2xl border border-border-subtle bg-surface p-6 mb-8">
        <div class="relative mb-5">
          <input
            id="pwd-output"
            type="text"
            readonly
            class="w-full font-mono text-lg bg-background border border-border-subtle rounded-lg pl-4 pr-32 py-4 text-foreground"
            placeholder="Click Generate to start"
          />
          <button
            id="pwd-copy"
            class="absolute right-2 top-1/2 -translate-y-1/2 px-3 py-1.5 rounded-md bg-accent text-background font-mono text-sm hover:bg-accent-hover transition-colors"
          >
            Copy
          </button>
        </div>

        <!-- Strength meter -->
        <div class="mb-6">
          <div class="flex items-center justify-between text-xs font-mono mb-2">
            <span class="text-text-secondary">Strength</span>
            <span id="pwd-strength-label" class="text-text-secondary">—</span>
          </div>
          <div class="w-full h-2 rounded-full bg-border-subtle overflow-hidden">
            <div
              id="pwd-strength-bar"
              class="h-full transition-all duration-200"
              style="width: 0%; background: var(--color-border-subtle);"
            ></div>
          </div>
          <div class="grid grid-cols-3 gap-2 mt-3 text-xs font-mono text-text-secondary">
            <div>Entropy: <span id="pwd-entropy" class="text-foreground">—</span></div>
            <div>Charset: <span id="pwd-charset" class="text-foreground">—</span></div>
            <div>Crack time: <span id="pwd-cracktime" class="text-foreground">—</span></div>
          </div>
        </div>

        <!-- Length slider -->
        <div class="mb-5">
          <label class="flex items-center justify-between text-sm font-sans mb-2">
            <span class="text-foreground">Length</span>
            <span id="pwd-length-label" class="font-mono text-accent">20</span>
          </label>
          <input
            id="pwd-length"
            type="range"
            min="6"
            max="64"
            value="20"
            class="w-full accent-current text-accent"
          />
        </div>

        <!-- Options -->
        <div class="grid grid-cols-2 gap-3 mb-6 text-sm font-sans">
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-upper" type="checkbox" checked />
            <span>Uppercase (A–Z)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-lower" type="checkbox" checked />
            <span>Lowercase (a–z)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-digits" type="checkbox" checked />
            <span>Numbers (0–9)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-symbols" type="checkbox" checked />
            <span>Symbols (!@#$…)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-exclude-similar" type="checkbox" />
            <span>Exclude similar (0/O/1/l)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pwd-exclude-ambiguous" type="checkbox" />
            <span>Exclude ambiguous brackets/slashes</span>
          </label>
        </div>

        <button
          id="pwd-generate"
          class="w-full py-3 rounded-lg bg-accent text-background font-mono font-bold hover:bg-accent-hover transition-colors"
        >
          Generate password
        </button>
      </section>

      <!-- CTA -->
      <section class="rounded-2xl border border-accent/30 bg-accent-muted/50 p-6 mb-10">
        <h2 class="text-xl font-mono font-bold text-foreground mb-2">
          Now share it securely
        </h2>
        <p class="text-sm text-text-secondary mb-4">
          Emailing a generated password defeats the point. CloakShare's secure-link feature: generate a one-time tracked link, set an expiry, send the link instead of the password. The recipient opens it once and the secret is gone.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-accent text-background font-mono text-sm hover:bg-accent-hover transition-colors"
          >
            How CloakShare works →
          </a>
          <a
            href="/use-cases/sales-enablement"
            class="inline-flex items-center gap-1 px-4 py-2 rounded-lg border border-border-subtle text-text-secondary font-mono text-sm hover:text-foreground transition-colors"
          >
            Use cases
          </a>
        </div>
      </section>

      <!-- How it works -->
      <section class="mb-10">
        <h2 class="text-2xl font-mono font-bold text-foreground mb-4">How the strength meter works</h2>
        <div class="space-y-4 text-sm text-text-secondary font-sans">
          <p>
            <span class="text-foreground font-medium">Entropy</span> measures how many guesses an attacker would have to try in the worst case. Calculated as <code class="font-mono text-xs bg-surface px-1.5 py-0.5 rounded">log₂(charset_size) × length</code>. A 20-character password drawing from 94 printable ASCII characters has ~131 bits of entropy.
          </p>
          <p>
            <span class="text-foreground font-medium">Crack time</span> assumes an offline attack against a stolen bcrypt hash with one modern GPU (~10,000 hashes/sec, Hashcat published benchmark). Online attacks against rate-limited login forms are vastly slower.
          </p>
          <p>
            <span class="text-foreground font-medium">Length beats complexity.</span> A 24-character lowercase-only password (~113 bits) is exponentially stronger than an 8-character password with all character classes (~52 bits). The strength meter weights length accordingly.
          </p>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-mono font-bold text-foreground mb-4">FAQ</h2>
        <div class="space-y-3">
          {faqs.map((f) => (
            <details class="rounded-lg border border-border-subtle bg-surface p-5">
              <summary class="cursor-pointer text-foreground font-medium text-sm">{f.question}</summary>
              <p class="mt-3 text-sm text-text-secondary font-sans">{f.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Cross-links -->
      <section class="grid sm:grid-cols-2 gap-4">
        <a
          href="/use-cases/investor-relations"
          class="rounded-lg border border-border-subtle bg-surface p-5 hover:border-accent/40 transition-colors"
        >
          <p class="font-mono font-bold text-foreground mb-1">Investor data rooms</p>
          <p class="text-sm text-text-secondary">Share decks and term sheets with per-recipient watermarks, expiry, and access logs.</p>
        </a>
        <a
          href="/use-cases/sales-enablement"
          class="rounded-lg border border-border-subtle bg-surface p-5 hover:border-accent/40 transition-colors"
        >
          <p class="font-mono font-bold text-foreground mb-1">Sales enablement</p>
          <p class="text-sm text-text-secondary">Track which pages prospects actually read. Watermarked PDFs and video links.</p>
        </a>
      </section>
    </div>
  </main>

  <script is:inline>
    (function () {
      const out = document.getElementById('pwd-output');
      const lengthInput = document.getElementById('pwd-length');
      const lengthLabel = document.getElementById('pwd-length-label');
      const generateBtn = document.getElementById('pwd-generate');
      const copyBtn = document.getElementById('pwd-copy');
      const upper = document.getElementById('pwd-upper');
      const lower = document.getElementById('pwd-lower');
      const digits = document.getElementById('pwd-digits');
      const symbols = document.getElementById('pwd-symbols');
      const excludeSimilar = document.getElementById('pwd-exclude-similar');
      const excludeAmbiguous = document.getElementById('pwd-exclude-ambiguous');
      const strengthBar = document.getElementById('pwd-strength-bar');
      const strengthLabel = document.getElementById('pwd-strength-label');
      const entropyEl = document.getElementById('pwd-entropy');
      const charsetEl = document.getElementById('pwd-charset');
      const cracktimeEl = document.getElementById('pwd-cracktime');

      function buildCharset() {
        let set = '';
        if (upper.checked) set += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
        if (lower.checked) set += 'abcdefghijklmnopqrstuvwxyz';
        if (digits.checked) set += '0123456789';
        if (symbols.checked) set += "!@#$%^&*-_=+[]{}|;:,.<>?/~";
        if (excludeSimilar.checked) {
          set = set.replace(/[0Ol1I]/g, "");
        }
        if (excludeAmbiguous.checked) {
          const ambig = ["{", "}", "[", "]", "(", ")", "/", "\\", ",", ";", ":", ".", "<", ">"];
          for (const c of ambig) {
            set = set.split(c).join("");
          }
        }
        return set;
      }

      function generate() {
        const len = parseInt(lengthInput.value, 10);
        const charset = buildCharset();
        if (!charset || charset.length === 0) {
          out.value = '';
          updateStrength('', 0);
          return;
        }
        // crypto.getRandomValues -> uniform sampling via rejection
        const result = [];
        const max = Math.floor(0xffffffff / charset.length) * charset.length;
        const buf = new Uint32Array(len * 2); // overprovision for rejection
        let bufIdx = 0;
        crypto.getRandomValues(buf);
        while (result.length < len) {
          if (bufIdx >= buf.length) {
            crypto.getRandomValues(buf);
            bufIdx = 0;
          }
          const r = buf[bufIdx++];
          if (r < max) {
            result.push(charset[r % charset.length]);
          }
        }
        const pwd = result.join('');
        out.value = pwd;
        updateStrength(pwd, charset.length);
      }

      function updateStrength(pwd, charsetSize) {
        if (!pwd) {
          strengthBar.style.width = '0%';
          strengthBar.style.background = 'var(--color-border-subtle)';
          strengthLabel.textContent = '—';
          entropyEl.textContent = '—';
          charsetEl.textContent = '—';
          cracktimeEl.textContent = '—';
          return;
        }
        const entropy = Math.log2(charsetSize) * pwd.length;
        entropyEl.textContent = entropy.toFixed(0) + ' bits';
        charsetEl.textContent = charsetSize + ' chars';

        // Crack time at 10,000 hashes/sec (bcrypt single GPU)
        const guesses = Math.pow(2, entropy - 1); // avg = half the keyspace
        const secs = guesses / 10000;
        cracktimeEl.textContent = formatTime(secs);

        // Strength tiers
        let pct, color, label;
        if (entropy < 40) { pct = 15; color = '#ef4444'; label = 'Weak'; }
        else if (entropy < 60) { pct = 35; color = '#f59e0b'; label = 'Fair'; }
        else if (entropy < 80) { pct = 55; color = '#eab308'; label = 'Good'; }
        else if (entropy < 100) { pct = 75; color = '#22c55e'; label = 'Strong'; }
        else { pct = 100; color = '#10b981'; label = 'Excellent'; }
        strengthBar.style.width = pct + '%';
        strengthBar.style.background = color;
        strengthLabel.textContent = label;
      }

      function formatTime(secs) {
        if (secs < 1) return '<1s';
        if (secs < 60) return Math.round(secs) + 's';
        if (secs < 3600) return Math.round(secs / 60) + 'm';
        if (secs < 86400) return Math.round(secs / 3600) + 'h';
        if (secs < 31536000) return Math.round(secs / 86400) + 'd';
        if (secs < 31536000000) return Math.round(secs / 31536000) + 'y';
        // > 1000 years
        const years = secs / 31536000;
        if (years < 1e6) return Math.round(years).toLocaleString() + 'y';
        if (years < 1e9) return (years / 1e6).toFixed(1) + 'M years';
        if (years < 1e12) return (years / 1e9).toFixed(1) + 'B years';
        if (years < 1e15) return (years / 1e12).toFixed(1) + 'T years';
        return '∞ (heat death of universe scale)';
      }

      lengthInput.addEventListener('input', () => {
        lengthLabel.textContent = lengthInput.value;
        generate();
      });
      [upper, lower, digits, symbols, excludeSimilar, excludeAmbiguous].forEach((el) =>
        el.addEventListener('change', generate),
      );
      generateBtn.addEventListener('click', generate);
      copyBtn.addEventListener('click', async () => {
        if (!out.value) return;
        try {
          await navigator.clipboard.writeText(out.value);
          const orig = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(() => (copyBtn.textContent = orig), 1500);
        } catch (e) {
          out.select();
          document.execCommand('copy');
        }
      });

      // Generate on first load
      generate();
    })();
  </script>
</Base>
