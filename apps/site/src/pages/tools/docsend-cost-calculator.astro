---
import Base from '../../layouts/Base.astro';

const title = 'DocSend Cost Calculator — How Much Are You Really Paying?';
const description =
  'Calculate your real DocSend cost and see how much you could save switching to CloakShare. Input your team size and plan — get an instant comparison with no signup.';

const faqs = [
  {
    question: 'How is the DocSend cost calculated?',
    answer:
      'DocSend charges per seat. Personal is $10/user/month, Standard is $45/user/month ($65 on monthly billing), and Advanced starts at $150/user/month. We multiply by your team size and show the annual total. CloakShare uses flat tiers with no per-seat fees.',
  },
  {
    question: 'What does CloakShare include that DocSend charges extra for?',
    answer:
      'DocSend locks watermarking, NDAs, and data rooms behind $150+/month Advanced plans. CloakShare includes dynamic watermarks, email gating, page-level analytics, and video support on all plans — including the free tier.',
  },
  {
    question: 'Can I self-host CloakShare to avoid paying entirely?',
    answer:
      'Yes. CloakShare is open source (MIT licensed) and self-hostable via Docker. Run it on any VPS with 1GB RAM. You get all features with no usage limits. The cloud plans add managed hosting, CDN, and support.',
  },
  {
    question: 'Does CloakShare have usage limits like DocSend?',
    answer:
      'DocSend Personal caps you at 100 views per link. CloakShare free tier includes 50 links and 500 views per month. Paid plans start at $29/month with higher limits and no per-seat fees. Self-hosted has no limits at all.',
  },
  {
    question: 'Does CloakShare support video like DocSend?',
    answer:
      'DocSend does not support video sharing. CloakShare includes HLS video streaming with adaptive quality (720p/1080p), per-viewer watermarks, and watch-time analytics on Starter plans and above.',
  },
];

const breadcrumbItems = [
  { name: 'Home', url: 'https://cloakshare.dev/' },
  { name: 'Tools', url: 'https://cloakshare.dev/tools' },
  { name: 'DocSend Cost Calculator', url: 'https://cloakshare.dev/tools/docsend-cost-calculator' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: b.url,
      })),
    },
    {
      '@type': 'WebApplication',
      name: 'DocSend Cost Calculator',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web Browser',
      description,
      url: 'https://cloakshare.dev/tools/docsend-cost-calculator',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
  ],
};
---

<Base title={title} description={description} canonical="/tools/docsend-cost-calculator">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    is:inline
  />

  <main class="pt-32 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Hero -->
      <section class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent/30 bg-accent-muted text-xs text-accent font-mono mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          Free · No signup · Instant results
        </div>
        <h1 class="text-4xl md:text-5xl font-mono font-bold text-foreground tracking-tight mb-4">
          DocSend Cost Calculator
        </h1>
        <p class="text-lg text-text-secondary font-sans max-w-2xl mx-auto">
          See what you're really paying for DocSend — and how much you'd save with CloakShare. Input your team size and plan for an instant comparison.
        </p>
      </section>

      <!-- Calculator -->
      <section class="rounded-2xl border border-border-subtle bg-surface p-6 mb-8">
        <!-- Team size -->
        <div class="mb-6">
          <label class="flex items-center justify-between text-sm font-sans mb-2">
            <span class="text-foreground font-medium">Team size</span>
            <span id="calc-team-label" class="font-mono text-accent">5 users</span>
          </label>
          <input
            id="calc-team"
            type="range"
            min="1"
            max="50"
            value="5"
            class="w-full accent-current text-accent"
          />
          <div class="flex justify-between text-xs text-text-tertiary font-mono mt-1">
            <span>1</span>
            <span>50</span>
          </div>
        </div>

        <!-- DocSend plan -->
        <div class="mb-6">
          <label class="text-sm text-foreground font-sans font-medium mb-3 block">Current DocSend plan</label>
          <div class="grid grid-cols-3 gap-3">
            <button id="plan-personal" class="calc-plan-btn rounded-lg border border-border-subtle bg-background p-3 text-center hover:border-accent/40 transition-colors" data-price="10">
              <div class="text-xs text-text-tertiary font-mono mb-1">Personal</div>
              <div class="text-lg font-mono font-bold text-foreground">$10</div>
              <div class="text-xs text-text-tertiary font-mono">/user/mo</div>
            </button>
            <button id="plan-standard" class="calc-plan-btn rounded-lg border-2 border-accent bg-accent/5 p-3 text-center" data-price="45">
              <div class="text-xs text-accent font-mono mb-1">Standard</div>
              <div class="text-lg font-mono font-bold text-foreground">$45</div>
              <div class="text-xs text-text-tertiary font-mono">/user/mo</div>
            </button>
            <button id="plan-advanced" class="calc-plan-btn rounded-lg border border-border-subtle bg-background p-3 text-center hover:border-accent/40 transition-colors" data-price="150">
              <div class="text-xs text-text-tertiary font-mono mb-1">Advanced</div>
              <div class="text-lg font-mono font-bold text-foreground">$150</div>
              <div class="text-xs text-text-tertiary font-mono">/user/mo</div>
            </button>
          </div>
        </div>

        <!-- Billing cycle -->
        <div class="mb-8">
          <label class="text-sm text-foreground font-sans font-medium mb-3 block">Billing cycle</label>
          <div class="grid grid-cols-2 gap-3">
            <button id="billing-annual" class="calc-billing-btn rounded-lg border-2 border-accent bg-accent/5 p-3 text-center" data-multiplier="1">
              <div class="text-sm font-mono font-medium text-foreground">Annual</div>
              <div class="text-xs text-text-tertiary font-mono">best price</div>
            </button>
            <button id="billing-monthly" class="calc-billing-btn rounded-lg border border-border-subtle bg-background p-3 text-center hover:border-accent/40 transition-colors" data-multiplier="1.44">
              <div class="text-sm font-mono font-medium text-foreground">Monthly</div>
              <div class="text-xs text-text-tertiary font-mono">~44% more</div>
            </button>
          </div>
        </div>

        <!-- Results -->
        <div class="border-t border-border-subtle pt-6">
          <div class="grid grid-cols-2 gap-6 mb-6">
            <div class="text-center">
              <div class="text-xs text-text-tertiary font-mono uppercase tracking-wider mb-2">DocSend cost</div>
              <div id="calc-docsend-monthly" class="text-2xl font-mono font-bold text-red-400">$225/mo</div>
              <div id="calc-docsend-annual" class="text-sm text-text-tertiary font-mono">$2,700/year</div>
            </div>
            <div class="text-center">
              <div class="text-xs text-text-tertiary font-mono uppercase tracking-wider mb-2">CloakShare cost</div>
              <div id="calc-cloak-monthly" class="text-2xl font-mono font-bold text-accent">$99/mo</div>
              <div id="calc-cloak-annual" class="text-sm text-text-tertiary font-mono">$1,188/year</div>
            </div>
          </div>

          <div id="calc-savings" class="rounded-lg bg-accent/10 border border-accent/30 p-4 text-center">
            <div class="text-xs text-accent font-mono uppercase tracking-wider mb-1">Annual savings with CloakShare</div>
            <div id="calc-savings-amount" class="text-3xl font-mono font-bold text-accent">$1,512</div>
            <div id="calc-savings-pct" class="text-sm text-accent/80 font-mono">56% less than DocSend</div>
          </div>
        </div>
      </section>

      <!-- Feature comparison -->
      <section class="rounded-2xl border border-border-subtle bg-surface p-6 mb-8">
        <h2 class="text-xl font-mono font-bold text-foreground mb-4">What you get for less</h2>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <span class="text-accent font-mono text-sm">+</span>
            </div>
            <div>
              <span class="text-sm text-foreground font-sans font-medium">Video support (HLS streaming)</span>
              <span class="text-sm text-text-tertiary font-sans"> — DocSend doesn't offer this at any price</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <span class="text-accent font-mono text-sm">+</span>
            </div>
            <div>
              <span class="text-sm text-foreground font-sans font-medium">Dynamic watermarks on all plans</span>
              <span class="text-sm text-text-tertiary font-sans"> — DocSend locks this behind Advanced ($150+/mo)</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <span class="text-accent font-mono text-sm">+</span>
            </div>
            <div>
              <span class="text-sm text-foreground font-sans font-medium">No per-seat pricing</span>
              <span class="text-sm text-text-tertiary font-sans"> — flat tiers for your whole team</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <span class="text-accent font-mono text-sm">+</span>
            </div>
            <div>
              <span class="text-sm text-foreground font-sans font-medium">Self-hosting option</span>
              <span class="text-sm text-text-tertiary font-sans"> — MIT licensed, Docker, full data control</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <span class="text-accent font-mono text-sm">+</span>
            </div>
            <div>
              <span class="text-sm text-foreground font-sans font-medium">REST API + SDKs</span>
              <span class="text-sm text-text-tertiary font-sans"> — Node.js, Python, Go, React, Web Component</span>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="rounded-2xl border border-accent/30 bg-accent-muted/50 p-6 mb-10">
        <h2 class="text-xl font-mono font-bold text-foreground mb-2">
          Stop overpaying for document sharing
        </h2>
        <p class="text-sm text-text-secondary mb-4">
          CloakShare's free tier includes 50 links and 500 views per month with email gating, watermarks, and page-level analytics. No credit card required.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://app.cloakshare.dev/register"
            class="inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-accent text-background font-mono text-sm hover:bg-accent-hover transition-colors"
          >
            Try CloakShare free →
          </a>
          <a
            href="/compare/docsend"
            class="inline-flex items-center gap-1 px-4 py-2 rounded-lg border border-border-subtle text-text-secondary font-mono text-sm hover:text-foreground transition-colors"
          >
            Full DocSend comparison
          </a>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-mono font-bold text-foreground mb-4">FAQ</h2>
        <div class="space-y-3">
          {faqs.map((f) => (
            <details class="rounded-lg border border-border-subtle bg-surface p-5">
              <summary class="cursor-pointer text-foreground font-medium text-sm">{f.question}</summary>
              <p class="mt-3 text-sm text-text-secondary font-sans">{f.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Cross-links -->
      <section class="grid sm:grid-cols-2 gap-4">
        <a
          href="/for/sales"
          class="rounded-lg border border-border-subtle bg-surface p-5 hover:border-accent/40 transition-colors"
        >
          <p class="font-mono font-bold text-foreground mb-1">For sales teams</p>
          <p class="text-sm text-text-secondary">Page-level analytics, real-time alerts, and video proposals. No per-seat pricing.</p>
        </a>
        <a
          href="/for/fundraising"
          class="rounded-lg border border-border-subtle bg-surface p-5 hover:border-accent/40 transition-colors"
        >
          <p class="font-mono font-bold text-foreground mb-1">For fundraising</p>
          <p class="text-sm text-text-secondary">Track which investors read your deck. Slide-by-slide analytics and dynamic watermarks.</p>
        </a>
      </section>
    </div>
  </main>

  <script is:inline>
    (function () {
      var teamSlider = document.getElementById('calc-team');
      var teamLabel = document.getElementById('calc-team-label');
      var planBtns = document.querySelectorAll('.calc-plan-btn');
      var billingBtns = document.querySelectorAll('.calc-billing-btn');
      var docsendMonthly = document.getElementById('calc-docsend-monthly');
      var docsendAnnual = document.getElementById('calc-docsend-annual');
      var cloakMonthly = document.getElementById('calc-cloak-monthly');
      var cloakAnnual = document.getElementById('calc-cloak-annual');
      var savingsAmount = document.getElementById('calc-savings-amount');
      var savingsPct = document.getElementById('calc-savings-pct');

      var state = { team: 5, price: 45, multiplier: 1 };

      var cloakPlans = [
        { name: 'Free', monthly: 0, limit: 1 },
        { name: 'Starter', monthly: 29, limit: 3 },
        { name: 'Growth', monthly: 99, limit: 15 },
        { name: 'Scale', monthly: 299, limit: 999 },
      ];

      function getCloakPlan(teamSize) {
        for (var i = cloakPlans.length - 1; i >= 0; i--) {
          if (teamSize <= cloakPlans[i].limit) {
            var plan = cloakPlans[i];
            if (i > 0) return plan;
          }
        }
        if (teamSize <= 1) return cloakPlans[0];
        if (teamSize <= 3) return cloakPlans[1];
        if (teamSize <= 15) return cloakPlans[2];
        return cloakPlans[3];
      }

      function calculate() {
        var team = state.team;
        var dsMonthly = Math.round(team * state.price * state.multiplier);
        var dsAnnual = dsMonthly * 12;

        var cloak = getCloakPlan(team);
        var ckMonthly = cloak.monthly;
        var ckAnnual = ckMonthly * 12;

        var savings = dsAnnual - ckAnnual;
        var pct = dsAnnual > 0 ? Math.round((savings / dsAnnual) * 100) : 0;

        docsendMonthly.textContent = '$' + dsMonthly.toLocaleString() + '/mo';
        docsendAnnual.textContent = '$' + dsAnnual.toLocaleString() + '/year';
        cloakMonthly.textContent = '$' + ckMonthly.toLocaleString() + '/mo';
        cloakAnnual.textContent = '$' + ckAnnual.toLocaleString() + '/year (' + cloak.name + ')';
        savingsAmount.textContent = '$' + savings.toLocaleString();
        savingsPct.textContent = pct + '% less than DocSend';
      }

      teamSlider.addEventListener('input', function () {
        state.team = parseInt(teamSlider.value, 10);
        teamLabel.textContent = state.team + ' user' + (state.team === 1 ? '' : 's');
        calculate();
      });

      planBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          planBtns.forEach(function (b) {
            b.classList.remove('border-2', 'border-accent', 'bg-accent/5');
            b.classList.add('border', 'border-border-subtle', 'bg-background');
            b.querySelector('div:first-child').classList.remove('text-accent');
            b.querySelector('div:first-child').classList.add('text-text-tertiary');
          });
          btn.classList.remove('border', 'border-border-subtle', 'bg-background');
          btn.classList.add('border-2', 'border-accent', 'bg-accent/5');
          btn.querySelector('div:first-child').classList.remove('text-text-tertiary');
          btn.querySelector('div:first-child').classList.add('text-accent');
          state.price = parseInt(btn.getAttribute('data-price'), 10);
          calculate();
        });
      });

      billingBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          billingBtns.forEach(function (b) {
            b.classList.remove('border-2', 'border-accent', 'bg-accent/5');
            b.classList.add('border', 'border-border-subtle', 'bg-background');
          });
          btn.classList.remove('border', 'border-border-subtle', 'bg-background');
          btn.classList.add('border-2', 'border-accent', 'bg-accent/5');
          state.multiplier = parseFloat(btn.getAttribute('data-multiplier'));
          calculate();
        });
      });

      calculate();
    })();
  </script>
</Base>
