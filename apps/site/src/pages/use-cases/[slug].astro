---
import Base from '../../layouts/Base.astro';
import { allUseCases } from '../../data/use-cases';
import { allIndustries } from '../../data/industries';
import type { UseCase } from '../../data/use-cases';

export function getStaticPaths() {
  return allUseCases.map((uc) => ({
    params: { slug: uc.slug },
    props: { useCase: uc },
  }));
}

interface Props {
  useCase: UseCase;
}

const { useCase } = Astro.props;

const title = `${useCase.name} Tool | CloakShare`;
const description = useCase.description.slice(0, 155) + '...';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cloakshare.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Use Cases", "item": "https://cloakshare.dev/use-cases/" },
    { "@type": "ListItem", "position": 3, "name": useCase.name, "item": `https://cloakshare.dev/use-cases/${useCase.slug}` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": useCase.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};

const relatedIndustries = useCase.relatedIndustries
  .map((slug) => allIndustries.find((i) => i.slug === slug))
  .filter(Boolean);

const otherUseCases = allUseCases.filter((uc) => uc.slug !== useCase.slug).slice(0, 4);
---

<Base title={title} description={description} canonical={`/use-cases/${useCase.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-xs font-mono text-text-tertiary">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li>/</li>
          <li><a href="/use-cases/pitch-deck-sharing" class="hover:text-accent transition-colors">Use Cases</a></li>
          <li>/</li>
          <li class="text-text-secondary">{useCase.name}</li>
        </ol>
      </nav>

      <p class="font-mono text-accent text-xs uppercase tracking-widest mb-4">Use Case</p>
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">{useCase.name}</h1>
      <p class="text-text-secondary font-sans text-lg mb-16 leading-relaxed max-w-2xl">
        {useCase.description}
      </p>

      <!-- Stats -->
      <div class="grid gap-6 md:grid-cols-3 mb-16">
        {useCase.stats.map((stat) => (
          <div class="bg-surface border border-accent/30 rounded-lg p-6 text-center">
            <div class="font-mono text-3xl font-bold text-accent mb-2">{stat.value}</div>
            <p class="text-xs text-text-tertiary font-sans leading-relaxed">{stat.label}</p>
          </div>
        ))}
      </div>

      <!-- Overview -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-4">The problem</h2>
        <p class="text-text-secondary font-sans leading-relaxed">
          {useCase.overview}
        </p>
      </div>

      <!-- Benefits -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Why CloakShare</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {useCase.benefits.map((benefit) => (
            <div class="flex items-start gap-3 bg-surface border border-border rounded-lg p-5">
              <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-text-secondary font-sans leading-relaxed">{benefit}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- How It Works -->
      <div class="mb-16 bg-surface border border-border rounded-lg p-8">
        <h2 class="font-mono font-medium text-foreground mb-6">How it works</h2>
        <div class="grid gap-6 md:grid-cols-4">
          <div>
            <div class="font-mono text-accent text-sm mb-2">01</div>
            <h3 class="font-mono text-sm text-foreground mb-1">Upload</h3>
            <p class="text-xs text-text-tertiary font-sans leading-relaxed">
              Upload your document (PDF, DOCX, PPTX, XLSX) or video (MP4, MOV, WebM) via API or dashboard.
            </p>
          </div>
          <div>
            <div class="font-mono text-accent text-sm mb-2">02</div>
            <h3 class="font-mono text-sm text-foreground mb-1">Configure</h3>
            <p class="text-xs text-text-tertiary font-sans leading-relaxed">
              Set email gating, password protection, dynamic watermarks, and link expiry to match your security needs.
            </p>
          </div>
          <div>
            <div class="font-mono text-accent text-sm mb-2">03</div>
            <h3 class="font-mono text-sm text-foreground mb-1">Share</h3>
            <p class="text-xs text-text-tertiary font-sans leading-relaxed">
              Send the tracked link. Recipients view in a secure canvas-based viewer. Videos stream via adaptive HLS.
            </p>
          </div>
          <div>
            <div class="font-mono text-accent text-sm mb-2">04</div>
            <h3 class="font-mono text-sm text-foreground mb-1">Analyze</h3>
            <p class="text-xs text-text-tertiary font-sans leading-relaxed">
              Track per-viewer engagement with page-level and video watch-time analytics. Get real-time webhook notifications.
            </p>
          </div>
        </div>
      </div>

      <!-- Video + Document Callout -->
      <div class="mb-16 bg-surface border border-accent/30 rounded-lg p-8">
        <h2 class="font-mono font-medium text-accent mb-4">Documents and video in one platform</h2>
        <p class="text-sm text-text-secondary font-sans leading-relaxed">
          CloakShare is the only secure sharing platform that combines document and video sharing with per-viewer analytics. Upload your PDF or presentation alongside a video walkthrough. Both are tracked, watermarked, and protected with the same access controls. No other tool does this.
        </p>
      </div>

      <!-- FAQs -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Frequently asked questions</h2>
        <div class="space-y-4">
          {useCase.faqs.map((faq) => (
            <details class="bg-surface border border-border rounded-lg group">
              <summary class="px-6 py-4 cursor-pointer font-mono text-sm text-foreground font-medium flex items-center justify-between">
                {faq.question}
                <svg class="w-4 h-4 text-text-tertiary flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4">
                <p class="text-sm text-text-secondary font-sans leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Related Industries -->
      {relatedIndustries.length > 0 && (
        <div class="mb-16">
          <h2 class="font-mono font-medium text-xl text-foreground mb-6">Popular with these industries</h2>
          <div class="grid gap-3 md:grid-cols-2">
            {relatedIndustries.map((ind) => (
              <a href={`/for/${ind!.slug}`} class="bg-surface border border-border rounded-lg p-4 hover:border-accent/50 transition-colors">
                <span class="text-sm font-mono text-foreground">{ind!.name}</span>
                <p class="text-xs text-text-tertiary font-sans mt-1 line-clamp-2">{ind!.description.slice(0, 100)}...</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Other Use Cases -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Other use cases</h2>
        <div class="grid gap-3 md:grid-cols-2">
          {otherUseCases.map((uc) => (
            <a href={`/use-cases/${uc.slug}`} class="bg-surface border border-border rounded-lg p-4 hover:border-accent/50 transition-colors">
              <span class="text-sm font-mono text-foreground">{uc.name}</span>
              <p class="text-xs text-text-tertiary font-sans mt-1 line-clamp-2">{uc.description.slice(0, 100)}...</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Compare Links -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Compare CloakShare</h2>
        <div class="flex flex-wrap gap-3">
          <a href="/compare/docsend" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs DocSend</a>
          <a href="/compare/papermark" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs Papermark</a>
          <a href="/compare/pandadoc" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs PandaDoc</a>
          <a href="/compare/brieflink" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs BriefLink</a>
          <a href="/compare/helprange" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs HelpRange</a>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center bg-surface border border-accent/30 rounded-lg p-10">
        <h2 class="font-mono font-bold text-2xl text-foreground mb-3">Start sharing securely</h2>
        <p class="text-text-secondary font-sans mb-6 max-w-lg mx-auto">
          Free tier includes 50 links and 500 views per month with email gating, watermarks, and page-level analytics. No credit card required.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
            Try CloakShare free
          </a>
          <a href="/self-hosted" class="px-6 py-2.5 border border-border text-foreground font-mono font-semibold text-sm rounded-md hover:border-accent/50 transition-colors">
            Self-host with Docker
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
