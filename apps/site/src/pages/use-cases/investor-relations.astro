---
import Base from '../../layouts/Base.astro';
---

<Base title="Investor Relations — Cloak" description="Share confidential fundraising documents with investors securely. Track who viewed your data room, watermark every page, and revoke access instantly." canonical="/use-cases/investor-relations">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-accent text-xs uppercase tracking-widest mb-4">Use Case</p>
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">Investor Relations</h1>
      <p class="text-text-secondary font-sans text-lg mb-16 leading-relaxed max-w-2xl">
        Share confidential fundraising documents with full control. Know exactly
        who accessed your data room, watermark every page, and revoke access
        the moment a deal falls through.
      </p>

      <div class="grid gap-8 md:grid-cols-2">
        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Secure data rooms</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Share term sheets, cap tables, financials, and due diligence materials through
            email-gated, watermarked, expiring links. No downloads, no forwarding.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Investor engagement tracking</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            See which investors opened your materials, how long they spent on each page,
            and whether they returned for a second look. Prioritize your follow-ups.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Instant revocation</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Deal fell through? Revoke access to all shared documents with a single API call.
            Set automatic expiry dates to ensure materials don't linger after the round closes.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Forensic watermarks</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Every page is watermarked with the viewer's email, date, and session ID.
            If a screenshot leaks, you can trace it back to the exact viewer and timestamp.
          </p>
        </div>
      </div>

      <div class="mt-16 bg-surface border border-accent/30 rounded-lg p-8">
        <h2 class="font-mono font-medium text-accent mb-4">Built for fundraising workflows</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Bulk upload entire data rooms with a single API call</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Domain-restrict access to specific investor email domains</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Webhook notifications integrate with your deal tracking tools</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">SOC 2-ready audit log tracks every access event</span>
          </li>
        </ul>
      </div>

      <div class="mt-12 text-center">
        <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
          Secure your data room
        </a>
        <p class="text-xs text-text-tertiary font-sans mt-3">Free tier includes 50 links/month</p>
      </div>
    </div>
  </section>
</Base>
