---
import Base from '../../layouts/Base.astro';
import { allIndustries } from '../../data/industries';
import type { Industry } from '../../data/industries';

export function getStaticPaths() {
  return allIndustries.map((ind) => ({
    params: { industry: ind.slug },
    props: { industry: ind },
  }));
}

interface Props {
  industry: Industry;
}

const { industry } = Astro.props;

const title = `Secure Document Sharing for ${industry.name} | CloakShare`;
const description = industry.description.slice(0, 155) + '...';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cloakshare.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://cloakshare.dev/for/" },
    { "@type": "ListItem", "position": 3, "name": industry.name, "item": `https://cloakshare.dev/for/${industry.slug}` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": industry.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};

const relatedUseCases = [
  { slug: 'pitch-deck-sharing', name: 'Pitch Deck Sharing' },
  { slug: 'proposal-tracking', name: 'Proposal Tracking' },
  { slug: 'contract-sharing', name: 'Contract Sharing' },
  { slug: 'data-room', name: 'Virtual Data Room' },
  { slug: 'video-proposals', name: 'Video Proposals' },
  { slug: 'training-content', name: 'Training Content' },
];

const relatedIndustries = allIndustries.filter((i) => i.slug !== industry.slug).slice(0, 4);
---

<Base title={title} description={description} canonical={`/for/${industry.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-xs font-mono text-text-tertiary">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li>/</li>
          <li><a href="/for/startups" class="hover:text-accent transition-colors">Industries</a></li>
          <li>/</li>
          <li class="text-text-secondary">{industry.name}</li>
        </ol>
      </nav>

      <p class="font-mono text-accent text-xs uppercase tracking-widest mb-4">For {industry.name}</p>
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">Secure Document Sharing for {industry.name}</h1>
      <p class="text-text-secondary font-sans text-lg mb-16 leading-relaxed max-w-2xl">
        {industry.description}
      </p>

      <!-- Pain Points -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">The problem</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {industry.painPoints.map((point) => (
            <div class="bg-surface border border-border rounded-lg p-5">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <p class="text-sm text-text-secondary font-sans leading-relaxed">{point}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- How CloakShare Solves It -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">How CloakShare solves it</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {industry.featuresNeeded.map((feature) => (
            <div class="bg-surface border border-border rounded-lg p-5">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <p class="text-sm text-text-secondary font-sans font-medium">{feature}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Typical Document Types -->
      <div class="mb-16 bg-surface border border-accent/30 rounded-lg p-8">
        <h2 class="font-mono font-medium text-accent mb-4">Documents {industry.name.toLowerCase()} share with CloakShare</h2>
        <div class="grid gap-3 md:grid-cols-2">
          {industry.typicalDocTypes.map((docType) => (
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="text-sm text-text-secondary font-sans">{docType}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Video + Document Advantage -->
      <div class="mb-16 bg-surface border border-border rounded-lg p-8">
        <h2 class="font-mono font-medium text-foreground mb-4">Video and document sharing in one platform</h2>
        <p class="text-sm text-text-secondary font-sans leading-relaxed mb-4">
          CloakShare is the only secure sharing platform that handles both documents and video. Upload MP4, MOV, or WebM files alongside your PDFs and presentations. Videos are automatically transcoded to adaptive HLS streaming with 720p and 1080p quality tiers, watermarked with the viewer's email on every frame, and tracked with per-viewer watch-time analytics.
        </p>
        <p class="text-sm text-text-secondary font-sans leading-relaxed">
          No other document sharing tool offers this. Not DocSend, not Papermark, not Digify. For {industry.name.toLowerCase()} that need to share both documents and video content, CloakShare eliminates the need for separate tools.
        </p>
      </div>

      <!-- FAQs -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Frequently asked questions</h2>
        <div class="space-y-4">
          {industry.faqs.map((faq) => (
            <details class="bg-surface border border-border rounded-lg group">
              <summary class="px-6 py-4 cursor-pointer font-mono text-sm text-foreground font-medium flex items-center justify-between">
                {faq.question}
                <svg class="w-4 h-4 text-text-tertiary flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4">
                <p class="text-sm text-text-secondary font-sans leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Cross-links -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Related use cases</h2>
        <div class="grid gap-3 md:grid-cols-3">
          {relatedUseCases.map((uc) => (
            <a href={`/use-cases/${uc.slug}`} class="bg-surface border border-border rounded-lg p-4 hover:border-accent/50 transition-colors">
              <span class="text-sm font-mono text-foreground">{uc.name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Other industries</h2>
        <div class="grid gap-3 md:grid-cols-2">
          {relatedIndustries.map((ind) => (
            <a href={`/for/${ind.slug}`} class="bg-surface border border-border rounded-lg p-4 hover:border-accent/50 transition-colors">
              <span class="text-sm font-mono text-foreground">{ind.name}</span>
              <p class="text-xs text-text-tertiary font-sans mt-1 line-clamp-2">{ind.description.slice(0, 100)}...</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Comparison links -->
      <div class="mb-16">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Compare CloakShare</h2>
        <div class="flex flex-wrap gap-3">
          <a href="/compare/docsend" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs DocSend</a>
          <a href="/compare/papermark" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs Papermark</a>
          <a href="/compare/pandadoc" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs PandaDoc</a>
          <a href="/compare/digify" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs Digify</a>
          <a href="/compare/brieflink" class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">vs BriefLink</a>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center bg-surface border border-accent/30 rounded-lg p-10">
        <h2 class="font-mono font-bold text-2xl text-foreground mb-3">Start sharing securely</h2>
        <p class="text-text-secondary font-sans mb-6 max-w-lg mx-auto">
          Free tier includes 50 links and 500 views per month with email gating, watermarks, and page-level analytics. No credit card required.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
            Try CloakShare free
          </a>
          <a href="/self-hosted" class="px-6 py-2.5 border border-border text-foreground font-mono font-semibold text-sm rounded-md hover:border-accent/50 transition-colors">
            Self-host with Docker
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
