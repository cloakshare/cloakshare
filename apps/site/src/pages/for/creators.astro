---
import Base from '../../layouts/Base.astro';
---

<Base title="For Creators — CloakShare" description="Share training videos and course materials securely with CloakShare. HLS streaming, dynamic watermarks, watch-time analytics, and email-gated access." canonical="/for/creators">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-accent text-xs uppercase tracking-widest mb-4">Use Case</p>
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">For Creators</h1>
      <p class="text-text-secondary font-sans text-lg mb-16 leading-relaxed max-w-2xl">
        Distribute course materials, training videos, and premium content with full control.
        Dynamic watermarks, email gates, and per-page engagement tracking protect your work
        and show who's actually learning.
      </p>

      <div class="grid gap-8 md:grid-cols-2">
        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">HLS video streaming</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Upload MP4, MOV, or WebM. Automatic transcoding to adaptive HLS with 720p and
            1080p quality tiers. No downloads — streaming only.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Dynamic watermarks</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Every page and video frame watermarked with the viewer's email and timestamp.
            If content leaks, trace it to the source.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Watch-time analytics</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            See which sections viewers watched, how long they spent, and their completion rate.
            Know who's engaged and who needs support.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <div class="w-10 h-10 bg-accent/15 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11v4m0 0l-2-2m2 2l2-2" />
            </svg>
          </div>
          <h3 class="font-mono font-medium text-foreground mb-2">Email-gated access</h3>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Require verified email before viewing. Control exactly who sees your content.
            Revoke access anytime.
          </p>
        </div>
      </div>

      <div class="mt-16 bg-surface border border-accent/30 rounded-lg p-8">
        <h2 class="font-mono font-medium text-accent mb-4">Built for content distribution</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Course materials rendered as secure, non-downloadable pages</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Video watermarks overlay viewer email on every frame</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Completion tracking shows who finished and who dropped off</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Expiring links ensure content access matches subscription periods</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary font-sans">Self-host for full control over student data and content</span>
          </li>
        </ul>
      </div>

      <div class="mt-12 text-center">
        <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
          Upload your first video
        </a>
        <p class="text-xs text-text-tertiary font-sans mt-3">Free tier: 50 links, 500 views per month</p>
      </div>
    </div>
  </section>
</Base>
