---

<Base title="Blog — Cloak" description="Product updates, tutorials, and insights on secure document and video sharing." canonical="/blog">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">Blog</h1>
      <p class="text-text-secondary font-sans leading-relaxed mb-6 max-w-2xl">
        Product updates, tutorials, and insights on secure document and video sharing. PDFs that actually expire, page-level analytics, watermark engineering.
      </p>
      <div class="mb-12 flex flex-wrap items-center gap-3 text-sm">
        <a
          href="https://app.cloakshare.dev/register"
          class="inline-block bg-accent text-background font-mono font-semibold px-5 py-2.5 rounded-md hover:bg-accent-hover transition-colors"
        >
          Try CloakShare Free
        </a>
        <a
          href="/pricing"
          class="inline-block border border-border text-foreground font-mono font-medium px-5 py-2.5 rounded-md hover:border-accent/40 transition-colors"
        >
          See Pricing
        </a>
        <span class="text-xs text-text-tertiary font-mono">
          50 links/mo free · 410 Gone semantics · per-page tracking
        </span>
      </div>

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="block bg-surface border border-border rounded-lg p-6 card-glow">
            <p class="text-xs text-text-tertiary font-mono mb-2">{post.date}</p>
            <h2 class="font-mono font-medium text-lg text-foreground mb-2">{post.title}</h2>
            <p class="text-sm text-text-secondary font-sans leading-relaxed">{post.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
