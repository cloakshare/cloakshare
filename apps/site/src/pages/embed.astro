<script>
  // Load the viewer component
  import('@cloakshare/viewer');

  // Copy install command
  const copyBtn = document.getElementById('copy-install');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText('npm install @cloakshare/viewer');
      copyBtn.textContent = 'Copied!';
      setTimeout(() => {
        copyBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>npm install @cloakshare/viewer`;
      }, 2000);
    });
  }

  // Interactive demo controls
  const watermarkCheck = document.getElementById('demo-watermark') as HTMLInputElement;
  const emailGateCheck = document.getElementById('demo-emailgate') as HTMLInputElement;
  const brandingCheck = document.getElementById('demo-branding') as HTMLInputElement;
  const watermarkText = document.getElementById('demo-watermark-text') as HTMLInputElement;
  const codePreview = document.getElementById('demo-code');
  const viewer = document.getElementById('demo-viewer');

  function updateDemo() {
    // Update code preview
    if (codePreview) {
      let code = '&lt;cloak-viewer\n  src="/sample-deck.pdf"';
      if (watermarkCheck?.checked && watermarkText?.value) {
        code += `\n  watermark="${watermarkText.value}"`;
      }
      if (emailGateCheck?.checked) {
        code += '\n  email-gate';
      }
      if (brandingCheck?.checked) {
        code += '\n  branding';
      }
      code += '\n/&gt;';
      codePreview.innerHTML = `<code>${code}</code>`;
    }

    // Update live viewer attributes
    if (viewer) {
      if (watermarkCheck?.checked && watermarkText?.value) {
        viewer.setAttribute('watermark', watermarkText.value);
      } else {
        viewer.removeAttribute('watermark');
      }
      if (emailGateCheck?.checked) {
        viewer.setAttribute('email-gate', '');
      } else {
        viewer.removeAttribute('email-gate');
      }
      viewer.setAttribute('branding', brandingCheck?.checked ? 'true' : 'false');
    }
  }

  watermarkCheck?.addEventListener('change', updateDemo);
  emailGateCheck?.addEventListener('change', updateDemo);
  brandingCheck?.addEventListener('change', updateDemo);
  watermarkText?.addEventListener('input', updateDemo);
</script>
