---
import Base from '../../layouts/Base.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const rows = [
  { feature: 'API-first', cloak: 'Yes', other: 'No' },
  { feature: 'Open source', cloak: 'MIT', other: 'No' },
  { feature: 'Self-hostable', cloak: 'Yes', other: 'No' },
  { feature: 'Video sharing', cloak: 'HLS streaming', other: 'No' },
  { feature: 'Office documents', cloak: 'DOCX, PPTX, XLSX', other: 'PDF only' },
  { feature: 'Per-seat pricing', cloak: 'No', other: '$65/user/mo' },
  { feature: 'Dynamic watermarks', cloak: 'Yes', other: 'Basic' },
  { feature: 'Canvas-based viewer', cloak: 'Yes', other: 'No' },
  { feature: 'Webhooks', cloak: 'Yes', other: 'No' },
  { feature: 'Custom domains', cloak: 'Yes', other: 'Enterprise only' },
  { feature: 'Embeddable viewer', cloak: 'npm package (free)', other: 'No (links only)' },
  { feature: 'Teams & RBAC', cloak: 'Yes', other: 'Yes' },
  { feature: 'Email gate', cloak: 'Yes', other: 'Yes' },
  { feature: 'Page-level analytics', cloak: 'Yes', other: 'Yes' },
  { feature: 'Password protection', cloak: 'Yes', other: 'Yes' },
  { feature: 'Link expiry', cloak: 'Yes', other: 'Yes' },
  { feature: 'Starting price', cloak: '$0 (free tier)', other: '$65/user/mo' },
];
---

<Base title="Cloak vs DocSend — Open-Source DocSend Alternative" description="Compare Cloak and DocSend for secure document and video sharing. API-first, open source, self-hostable, with video support. 3x cheaper." canonical="/compare/docsend">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">Cloak vs DocSend</h1>
      <p class="text-text-secondary font-sans mb-12 leading-relaxed max-w-2xl">
        DocSend is a GUI-based document sharing tool at $65/user/month. Cloak is an API-first
        alternative that's open source, self-hostable, supports video sharing, and starts free.
      </p>

      <ComparisonTable competitor="DocSend" rows={rows} />

      <div class="mt-12 space-y-6">
        <div class="bg-surface border border-accent/30 rounded-lg p-6">
          <h2 class="font-mono font-medium text-accent mb-3">Video sharing</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            DocSend doesn't support video. Cloak lets you upload MP4, MOV, or WebM files and
            automatically transcodes them to adaptive HLS streaming with 720p and 1080p quality tiers.
            Videos are watermarked with a canvas overlay and protected with per-segment signed URLs.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <h2 class="font-mono font-medium text-foreground mb-3">API-first vs GUI-only</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            DocSend requires manual uploads through their web interface. Cloak lets you integrate
            secure document and video sharing directly into your product with a single API call. Automate
            link creation from your CRM, generate secure links in your onboarding flow, or embed
            the viewer directly in your app.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <h2 class="font-mono font-medium text-foreground mb-3">Per-account vs per-seat pricing</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            DocSend charges $65/user/month. A team of 10 costs $650/month. Cloak's Growth plan
            at $99/month covers your entire team with 2,500 links, 25,000 views, and video support. That's 6.5x
            cheaper for a 10-person team.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <h2 class="font-mono font-medium text-foreground mb-3">Open source &amp; self-hostable</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Cloak's core is MIT licensed and self-hostable. Run it on your own servers for complete
            data sovereignty. DocSend is a closed-source SaaS with no self-hosting option.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
          Try Cloak free
        </a>
      </div>
    </div>
  </section>
</Base>
