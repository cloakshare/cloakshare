---
import Base from '../../layouts/Base.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const rows = [
  { feature: 'API-first', cloak: 'Yes', other: 'Limited' },
  { feature: 'Open source', cloak: 'MIT', other: 'AGPL' },
  { feature: 'Video sharing', cloak: 'HLS streaming', other: 'No' },
  { feature: 'Office documents', cloak: 'DOCX, PPTX, XLSX', other: 'Limited' },
  { feature: 'Canvas-based viewer', cloak: 'Yes', other: 'No (DOM-based)' },
  { feature: 'Dynamic watermarks', cloak: 'Per-session', other: 'Basic' },
  { feature: 'Webhooks', cloak: 'Yes', other: 'No' },
  { feature: 'Custom domains', cloak: 'Yes', other: 'Yes' },
  { feature: 'Embeddable viewer', cloak: 'Yes', other: 'No' },
  { feature: 'Teams & RBAC', cloak: 'Yes', other: 'Yes' },
  { feature: 'Email gate', cloak: 'Yes', other: 'Yes' },
  { feature: 'Print protection', cloak: 'CSS + headers', other: 'No' },
  { feature: 'Page-level analytics', cloak: 'Yes', other: 'Yes' },
  { feature: 'Background rendering', cloak: 'Yes', other: 'Client-side' },
  { feature: 'Screenshot protection', cloak: 'Permissions-Policy', other: 'No' },
];
---

<Base title="Cloak vs Papermark — Comparison" description="Compare Cloak and Papermark for secure document sharing. Stronger security with canvas rendering, video support, and MIT license." canonical="/compare/papermark">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">Cloak vs Papermark</h1>
      <p class="text-text-secondary font-sans mb-12 leading-relaxed max-w-2xl">
        Papermark is an open-source DocSend alternative (AGPL). Cloak takes a different approach
        with a stronger security model: server-side rendering to canvas prevents content extraction
        that's possible with Papermark's DOM-based viewer. Plus, Cloak supports video sharing.
      </p>

      <ComparisonTable competitor="Papermark" rows={rows} />

      <div class="mt-12 space-y-6">
        <div class="bg-surface border border-accent/30 rounded-lg p-6">
          <h2 class="font-mono font-medium text-accent mb-3">Video sharing</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Papermark doesn't support video. Cloak transcodes uploads to adaptive HLS streaming with
            canvas watermark overlay, watch time analytics, and per-segment signed URLs. Share training
            videos, product demos, and investor presentations with the same security as documents.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <h2 class="font-mono font-medium text-foreground mb-3">Security model</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Papermark renders documents in the DOM, making content accessible via browser DevTools.
            Cloak renders documents server-side to images, then draws them to a Canvas element.
            The original document content never exists in the DOM, making it significantly harder
            to extract.
          </p>
        </div>

        <div class="bg-surface border border-border rounded-lg p-6">
          <h2 class="font-mono font-medium text-foreground mb-3">MIT vs AGPL licensing</h2>
          <p class="text-sm text-text-secondary font-sans leading-relaxed">
            Cloak uses the MIT license, which allows unrestricted commercial use, modification,
            and integration. Papermark uses AGPL, which requires you to open-source your entire
            application if you modify or integrate Papermark's code.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
          Try Cloak free
        </a>
      </div>
    </div>
  </section>
</Base>
