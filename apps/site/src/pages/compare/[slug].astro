---
import Base from '../../layouts/Base.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import { allCompetitors } from '../../data/competitors';
import type { Competitor } from '../../data/competitors';

export function getStaticPaths() {
  return allCompetitors.map((comp) => ({
    params: { slug: comp.slug },
    props: { competitor: comp },
  }));
}

interface Props {
  competitor: Competitor;
}

const { competitor } = Astro.props;

const title = `CloakShare vs ${competitor.name} | ${competitor.name} Alternative`;
const description = `Compare CloakShare and ${competitor.name} for secure document and video sharing. See features, pricing, and why teams switch to CloakShare.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cloakshare.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://cloakshare.dev/compare/" },
    { "@type": "ListItem", "position": 3, "name": `vs ${competitor.name}`, "item": `https://cloakshare.dev/compare/${competitor.slug}` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": competitor.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};

const otherCompetitors = allCompetitors.filter((c) => c.slug !== competitor.slug);
---

<Base title={title} description={description} canonical={`/compare/${competitor.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-xs font-mono text-text-tertiary">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li>/</li>
          <li><a href="/compare/docsend" class="hover:text-accent transition-colors">Compare</a></li>
          <li>/</li>
          <li class="text-text-secondary">vs {competitor.name}</li>
        </ol>
      </nav>

      <h1 class="font-mono font-bold text-4xl text-foreground mb-4">CloakShare vs {competitor.name}</h1>
      <p class="text-text-secondary font-sans mb-12 leading-relaxed max-w-2xl">
        Looking for a {competitor.name} alternative? CloakShare is an open-source, API-first platform for secure document and video sharing with watermarks, tracking, and expiry. Here is how they compare.
      </p>

      <!-- Pricing Comparison -->
      <div class="mb-12 bg-surface border border-accent/30 rounded-lg p-6">
        <h2 class="font-mono font-medium text-accent mb-3">Pricing</h2>
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <p class="text-xs font-mono text-text-tertiary uppercase tracking-wider mb-1">CloakShare</p>
            <p class="text-sm text-text-secondary font-sans">$0 free tier (50 links, 500 views). Growth at $99/month. No per-seat fees.</p>
          </div>
          <div>
            <p class="text-xs font-mono text-text-tertiary uppercase tracking-wider mb-1">{competitor.name}</p>
            <p class="text-sm text-text-secondary font-sans">{competitor.pricing}</p>
          </div>
        </div>
      </div>

      <!-- Feature Comparison Table -->
      <div class="mb-12">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Feature comparison</h2>
        <ComparisonTable competitor={competitor.name} rows={competitor.features} />
      </div>

      <!-- CloakShare Advantages -->
      <div class="mb-12">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Why switch to CloakShare</h2>
        <div class="space-y-4">
          {competitor.cloakshareAdvantages.map((advantage) => (
            <div class="bg-surface border border-border rounded-lg p-5">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <p class="text-sm text-text-secondary font-sans leading-relaxed">{advantage}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Competitor Strengths (fair comparison) -->
      <div class="mb-12 grid gap-8 md:grid-cols-2">
        <div>
          <h2 class="font-mono font-medium text-foreground mb-4">Where {competitor.name} is strong</h2>
          <ul class="space-y-3">
            {competitor.strengths.map((s) => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-text-tertiary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-text-secondary font-sans">{s}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-mono font-medium text-foreground mb-4">Where {competitor.name} falls short</h2>
          <ul class="space-y-3">
            {competitor.weaknesses.map((w) => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <span class="text-sm text-text-secondary font-sans">{w}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Video Advantage -->
      <div class="mb-12 bg-surface border border-border rounded-lg p-8">
        <h2 class="font-mono font-medium text-foreground mb-4">Video sharing: CloakShare's unique advantage</h2>
        <p class="text-sm text-text-secondary font-sans leading-relaxed mb-4">
          {competitor.name} does not offer secure video sharing. CloakShare lets you upload MP4, MOV, or WebM files and automatically transcodes them to adaptive HLS streaming with 720p and 1080p quality tiers. Every video frame is watermarked with the viewer's email. Watch-time analytics show exactly how much each viewer watched.
        </p>
        <p class="text-sm text-text-secondary font-sans leading-relaxed">
          For teams that need to share both documents and video content, CloakShare eliminates the need for separate tools and gives you unified analytics across all content types.
        </p>
      </div>

      <!-- Self-hosted callout -->
      <div class="mb-12 bg-surface border border-border rounded-lg p-8">
        <h2 class="font-mono font-medium text-foreground mb-4">Self-hosted option</h2>
        <p class="text-sm text-text-secondary font-sans leading-relaxed mb-4">
          CloakShare is open source (MIT license) and self-hostable via Docker. Run it on your own infrastructure for complete data sovereignty. {competitor.name} is a closed-source SaaS with no self-hosting option.
        </p>
        <a href="/self-hosted" class="text-sm font-mono text-accent hover:underline">Learn about self-hosting CloakShare</a>
      </div>

      <!-- FAQs -->
      <div class="mb-12">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Frequently asked questions</h2>
        <div class="space-y-4">
          {competitor.faqs.map((faq) => (
            <details class="bg-surface border border-border rounded-lg group">
              <summary class="px-6 py-4 cursor-pointer font-mono text-sm text-foreground font-medium flex items-center justify-between">
                {faq.question}
                <svg class="w-4 h-4 text-text-tertiary flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4">
                <p class="text-sm text-text-secondary font-sans leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Other Comparisons -->
      <div class="mb-12">
        <h2 class="font-mono font-medium text-xl text-foreground mb-6">Other comparisons</h2>
        <div class="flex flex-wrap gap-3">
          {otherCompetitors.map((c) => (
            <a href={`/compare/${c.slug}`} class="text-xs font-mono text-accent border border-accent/30 rounded px-3 py-1.5 hover:bg-accent/10 transition-colors">
              vs {c.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Industry + Use Case Cross-links -->
      <div class="mb-12 grid gap-8 md:grid-cols-2">
        <div>
          <h2 class="font-mono font-medium text-foreground mb-4">Industries</h2>
          <div class="flex flex-wrap gap-2">
            <a href="/for/startups" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Startups</a>
            <a href="/for/law-firms" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Law Firms</a>
            <a href="/for/real-estate" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Real Estate</a>
            <a href="/for/consulting" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Consulting</a>
            <a href="/for/healthcare" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Healthcare</a>
            <a href="/for/franchise" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Franchise</a>
          </div>
        </div>
        <div>
          <h2 class="font-mono font-medium text-foreground mb-4">Use cases</h2>
          <div class="flex flex-wrap gap-2">
            <a href="/use-cases/pitch-deck-sharing" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Pitch Decks</a>
            <a href="/use-cases/proposal-tracking" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Proposals</a>
            <a href="/use-cases/data-room" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Data Room</a>
            <a href="/use-cases/video-proposals" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Video Proposals</a>
            <a href="/use-cases/contract-sharing" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">Contracts</a>
            <a href="/use-cases/nda-sharing" class="text-xs font-mono text-text-secondary border border-border rounded px-3 py-1.5 hover:border-accent/50 transition-colors">NDAs</a>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center bg-surface border border-accent/30 rounded-lg p-10">
        <h2 class="font-mono font-bold text-2xl text-foreground mb-3">Switch to CloakShare</h2>
        <p class="text-text-secondary font-sans mb-6 max-w-lg mx-auto">
          Free tier includes 50 links and 500 views per month with email gating, watermarks, and analytics. No credit card required.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
            Try CloakShare free
          </a>
          <a href="https://github.com/cloakshare/cloakshare" class="px-6 py-2.5 border border-border text-foreground font-mono font-semibold text-sm rounded-md hover:border-accent/50 transition-colors">
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
