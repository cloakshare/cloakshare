---
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Pricing', href: '/pricing' },
      { label: 'Security', href: '/security' },
      { label: 'Changelog', href: '/changelog' },
      { label: 'Blog', href: '/blog' },
    ],
  },
  {
    title: 'Developers',
    links: [
      { label: 'Documentation', href: 'https://github.com/cloakshare/cloakshare' },
      { label: 'API Reference', href: 'https://api.cloakshare.dev/docs' },
      { label: 'Self-hosting', href: 'https://github.com/cloakshare/cloakshare/blob/main/docs/self-hosting.md' },
      { label: 'GitHub', href: 'https://github.com/cloakshare/cloakshare' },
    ],
  },
  {
    title: 'Compare',
    links: [
      { label: 'vs DocSend', href: '/compare/docsend' },
      { label: 'vs Digify', href: '/compare/digify' },
      { label: 'vs Papermark', href: '/compare/papermark' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Service', href: '/terms' },
      { label: 'GDPR', href: '/security#gdpr' },
    ],
  },
];
---

<footer class="border-t border-border mt-24">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <div class="col-span-2 md:col-span-1">
        <span class="flex items-center gap-2 font-mono font-bold text-lg text-foreground tracking-tight">
          <img src="/logo.png" alt="CloakShare" class="w-6 h-6" />
          CloakShare
        </span>
        <p class="text-sm text-text-tertiary mt-3 font-sans leading-relaxed">
          Secure document sharing as an API. Open source.
        </p>
      </div>
      {columns.map(col => (
        <div>
          <h4 class="text-xs text-text-tertiary font-mono uppercase tracking-wider mb-4">{col.title}</h4>
          <ul class="space-y-2.5">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-text-secondary hover:text-text-primary transition-colors font-sans">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 pt-8 border-t border-border-subtle flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-tertiary font-mono">&copy; {new Date().getFullYear()} CloakShare. MIT License.</p>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com/cloakshare" class="text-text-tertiary hover:text-text-primary transition-colors" target="_blank" rel="noopener">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/cloakshare/cloakshare" class="text-text-tertiary hover:text-text-primary transition-colors" target="_blank" rel="noopener">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
