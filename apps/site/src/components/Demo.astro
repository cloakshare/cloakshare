---
---

<section id="demo" class="py-20 px-6 border-t border-border-subtle">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-center font-mono font-semibold text-2xl text-foreground mb-4">Try it &mdash; no signup required</h2>
    <p class="text-center text-text-secondary font-sans mb-12 max-w-xl mx-auto">See how Cloak secures a document or video in under 10 seconds. This uses the real API.</p>

    <div id="demo-app" class="bg-surface border border-border rounded-lg overflow-hidden">
      <!-- Step 1: Upload / Select -->
      <div id="demo-upload" class="p-8">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <div
              id="demo-dropzone"
              class="border-2 border-dashed border-border rounded-lg p-8 text-center cursor-pointer hover:border-accent/30 transition-colors"
            >
              <svg class="w-8 h-8 mx-auto text-text-tertiary mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
              <p class="text-sm text-text-secondary font-sans mb-1">Drop a file here, or click to upload</p>
              <p class="text-xs text-text-tertiary font-mono">PDF, images, Office docs, or video &middot; max 20 MB</p>
              <input type="file" id="demo-file-input" accept=".pdf,.png,.jpg,.jpeg,.webp,.docx,.doc,.pptx,.ppt,.odt,.odp,.rtf,.mp4,.mov,.webm" class="hidden" />
            </div>
            <div class="mt-4">
              <p class="text-xs text-text-tertiary font-mono mb-2">Or try a sample:</p>
              <div class="flex flex-col gap-2">
                <button class="demo-sample-btn text-left px-3 py-2 rounded-md border border-border-subtle bg-background text-sm font-mono text-text-secondary hover:text-text-primary hover:border-border transition-all" data-sample="sales-proposal">
                  Q4 Sales Proposal &middot; PDF &middot; 6 pages
                </button>
                <button class="demo-sample-btn text-left px-3 py-2 rounded-md border border-border-subtle bg-background text-sm font-mono text-text-secondary hover:text-text-primary hover:border-border transition-all" data-sample="pitch-deck">
                  Series A Pitch Deck &middot; PPTX &middot; 12 pages
                </button>
                <button class="demo-sample-btn text-left px-3 py-2 rounded-md border border-accent/30 bg-accent-muted/30 text-sm font-mono text-accent hover:text-accent-hover hover:border-accent/50 transition-all" data-sample="training-video">
                  Product Demo &middot; MP4 &middot; 2:30
                </button>
              </div>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-mono text-foreground mb-4">Configure</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <label class="text-sm text-text-secondary font-sans">Expires in</label>
                <select id="demo-expiry" class="bg-input border border-border rounded-md px-3 py-1.5 text-sm font-mono text-foreground">
                  <option value="1h">1 hour</option>
                  <option value="24h" selected>24 hours</option>
                  <option value="72h">72 hours</option>
                  <option value="7d">7 days</option>
                </select>
              </div>
              <div class="flex items-center justify-between">
                <label class="text-sm text-text-secondary font-sans">Require email</label>
                <input type="checkbox" id="demo-email" checked class="accent-accent" />
              </div>
              <div class="flex items-center justify-between">
                <label class="text-sm text-text-secondary font-sans">Watermark</label>
                <input type="checkbox" id="demo-watermark" checked class="accent-accent" />
              </div>
              <div>
                <label class="text-sm text-text-secondary font-sans block mb-1.5">Password (optional)</label>
                <input type="text" id="demo-password" placeholder="Leave blank for none" class="w-full bg-input border border-border rounded-md px-3 py-1.5 text-sm font-mono text-foreground outline-none focus:border-accent/50 transition-colors" />
              </div>
            </div>
          </div>
        </div>
        <div class="mt-6 text-center">
          <button
            id="demo-submit"
            disabled
            class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
          >
            Secure this document
          </button>
        </div>
      </div>

      <!-- Step 2: Progress -->
      <div id="demo-progress" class="p-8 hidden">
        <div class="max-w-md mx-auto">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs font-mono text-text-tertiary">POST api.cloakshare.dev/v1/links</span>
          </div>
          <div id="demo-progress-steps" class="space-y-2 font-mono text-sm"></div>
          <div id="demo-progress-bar" class="mt-4 h-1 bg-elevated rounded-full overflow-hidden">
            <div id="demo-progress-fill" class="h-full bg-accent rounded-full transition-all duration-300" style="width: 0%"></div>
          </div>
        </div>
      </div>

      <!-- Step 3: Result -->
      <div id="demo-result" class="p-8 hidden">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <p class="text-accent font-mono text-sm mb-3">Your document is secured</p>
            <div class="bg-background border border-border-subtle rounded-md p-4 mb-4">
              <p class="text-xs text-text-tertiary font-mono mb-1">Secure URL</p>
              <div class="flex items-center gap-2">
                <code id="demo-url" class="text-sm text-accent font-mono break-all flex-1"></code>
                <button id="demo-copy" class="text-xs text-text-tertiary font-mono hover:text-text-primary transition-colors">Copy</button>
              </div>
            </div>
            <a id="demo-open-viewer" href="#" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 bg-elevated border border-border rounded-md text-sm font-mono text-text-secondary hover:text-text-primary transition-colors">
              Open Viewer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
          <div>
            <p class="text-text-tertiary font-mono text-xs uppercase tracking-wider mb-3">Live Analytics</p>
            <div id="demo-analytics" class="bg-background border border-border-subtle rounded-md p-4">
              <p class="text-sm text-text-tertiary font-mono">Waiting for first view&hellip;</p>
            </div>
          </div>
        </div>
        <div class="mt-6 text-center">
          <p class="text-text-secondary font-sans text-sm mb-3">That was 1 API call.</p>
          <a href="https://app.cloakshare.dev/register" class="px-6 py-2.5 bg-accent text-background font-mono font-semibold text-sm rounded-md hover:bg-accent-hover transition-colors">
            Get your API key &mdash; free
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const API_BASE = 'https://api.cloakshare.dev';

  const dropzone = document.getElementById('demo-dropzone')!;
  const fileInput = document.getElementById('demo-file-input') as HTMLInputElement;
  const submitBtn = document.getElementById('demo-submit') as HTMLButtonElement;
  const uploadSection = document.getElementById('demo-upload')!;
  const progressSection = document.getElementById('demo-progress')!;
  const resultSection = document.getElementById('demo-result')!;

  let selectedFile: File | null = null;

  // File selection
  dropzone.addEventListener('click', () => fileInput.click());
  dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-accent/40'); });
  dropzone.addEventListener('dragleave', () => dropzone.classList.remove('border-accent/40'));
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-accent/40');
    const files = (e as DragEvent).dataTransfer?.files;
    if (files?.[0]) selectFile(files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) selectFile(fileInput.files[0]); });

  // Sample buttons — disabled for now (no pre-built samples)
  document.querySelectorAll('.demo-sample-btn').forEach(btn => {
    (btn as HTMLButtonElement).disabled = true;
    btn.classList.add('opacity-40', 'cursor-not-allowed');
  });

  const SUPPORTED_EXTS = ['.pdf','.png','.jpg','.jpeg','.webp','.docx','.doc','.pptx','.ppt','.odt','.odp','.rtf','.mp4','.mov','.webm'];
  const VIDEO_EXTS = ['.mp4','.mov','.webm'];

  function selectFile(file: File) {
    const ext = '.' + file.name.split('.').pop()?.toLowerCase();
    if (!SUPPORTED_EXTS.includes(ext)) {
      alert('Unsupported file type. Try PDF, images, Office docs, or video.'); return;
    }
    if (file.size > 20 * 1024 * 1024) { alert('Demo files must be under 20 MB'); return; }
    selectedFile = file;
    submitBtn.disabled = false;
    const isVideo = VIDEO_EXTS.includes(ext);
    const label = isVideo ? 'Video' : 'Document';
    submitBtn.textContent = `Secure "${file.name}"`;
    dropzone.innerHTML = `<p class="text-sm text-accent font-mono">${label}: ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)</p>`;
  }

  // Submit — calls real API
  submitBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    uploadSection.classList.add('hidden');
    progressSection.classList.remove('hidden');

    const progressSteps = document.getElementById('demo-progress-steps')!;
    const progressFill = document.getElementById('demo-progress-fill')!;

    // Step 1: Upload to API
    function addStep(text: string) {
      const el = document.createElement('div');
      el.className = 'flex items-center gap-2';
      el.innerHTML = `<span class="text-accent">&#10003;</span> <span class="text-text-secondary">${text}</span>`;
      progressSteps.appendChild(el);
    }

    addStep('Uploading file...');
    progressFill.style.width = '20%';

    try {
      const formData = new FormData();
      formData.append('file', selectedFile);

      const res = await fetch(`${API_BASE}/v1/demo/link`, {
        method: 'POST',
        body: formData,
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: { message: 'Upload failed' } }));
        throw new Error(err.error?.message || 'Upload failed');
      }

      const data = await res.json();
      const linkId = data.data.id;
      const secureUrl = data.data.secure_url;
      const progressUrl = data.data.progress_url;

      addStep('File received');
      progressFill.style.width = '40%';

      // Step 2: Poll for rendering progress
      let status = 'processing';
      while (status === 'processing') {
        await new Promise(r => setTimeout(r, 1500));
        try {
          const progressRes = await fetch(progressUrl);
          if (progressRes.ok) {
            const progress = await progressRes.json();
            const p = progress.data || progress;
            if (p.status === 'active' || p.status === 'completed') {
              status = 'active';
              progressFill.style.width = '100%';
              addStep('Rendering complete');
            } else if (p.status === 'failed') {
              throw new Error('Rendering failed');
            } else if (p.progress) {
              const pct = 40 + (p.progress.percent || 0) * 0.6;
              progressFill.style.width = pct + '%';
              if (p.progress.message) addStep(p.progress.message);
            }
          }
        } catch (e) {
          // Progress endpoint may not exist yet, keep polling
        }
      }

      addStep('Secure link generated');

      await new Promise(r => setTimeout(r, 500));
      progressSection.classList.add('hidden');
      resultSection.classList.remove('hidden');

      (document.getElementById('demo-url') as HTMLElement).textContent = secureUrl;
      (document.getElementById('demo-open-viewer') as HTMLAnchorElement).href = secureUrl;
    } catch (err: any) {
      progressSection.classList.add('hidden');
      uploadSection.classList.remove('hidden');
      progressSteps.innerHTML = '';
      progressFill.style.width = '0%';
      alert(err.message || 'Something went wrong. Please try again.');
    }
  });

  // Copy button
  document.getElementById('demo-copy')?.addEventListener('click', () => {
    const url = document.getElementById('demo-url')?.textContent;
    if (url) {
      navigator.clipboard.writeText(url);
      const btn = document.getElementById('demo-copy')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    }
  });
</script>
