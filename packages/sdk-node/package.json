{
  "name": "@cloakshare/sdk",
  "version": "0.1.0",
  "description": "Official CloakShare Node.js SDK — secure document and video sharing API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "homepage": "https://docs.cloakshare.dev/sdks/node",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloakshare/cloakshare",
    "directory": "packages/sdk-node"
  },
  "keywords": ["cloakshare", "document-sharing", "secure-links", "watermark", "api", "sdk"],
  "publishConfig": {
    "access": "public"
  }
}
