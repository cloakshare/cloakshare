# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
VIEWER_URL=http://localhost:5173

# Mode: 'self-hosted' | 'cloud'
CLOAK_MODE=self-hosted

# Database
DB_PROVIDER=sqlite
SQLITE_PATH=./data/cloak.db
# For cloud mode (Turso):
# DB_PROVIDER=turso
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data/renders
# For cloud mode (R2/S3):
# STORAGE_PROVIDER=s3
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=cloak-renders
# Or generic S3:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=xxx
# S3_SECRET_ACCESS_KEY=xxx
# S3_BUCKET_NAME=cloak-renders
# S3_FORCE_PATH_STYLE=false

# Auth — REQUIRED in production (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-another-random-64-char-string
CLOAK_SIGNING_SECRET=change-me-to-yet-another-random-string

# Dashboard URL (for CORS in production)
# DASHBOARD_URL=http://localhost:5174

# CORS origins (comma-separated, used in production)
# CORS_ORIGINS=https://cloakshare.dev,https://app.cloakshare.dev

# Video support (self-hosted mode — requires ffmpeg installed)
# ENABLE_VIDEO=true
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Office document conversion (requires LibreOffice installed)
# LIBREOFFICE_PATH=/usr/bin/libreoffice

# Stripe (cloud mode only)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_STARTER_PRICE_ID=price_xxx
# STRIPE_GROWTH_PRICE_ID=price_xxx
# STRIPE_SCALE_PRICE_ID=price_xxx
# STRIPE_LINK_METER_ID=mtr_xxx
# STRIPE_VIEW_METER_ID=mtr_xxx

# Email (cloud mode only)
# RESEND_API_KEY=re_xxx
# FROM_EMAIL=noreply@cloakshare.dev

# Logging
LOG_LEVEL=info
